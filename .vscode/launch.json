    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Launch",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/Api/bin/Debug/net10.0/Api.dll",
            "cwd": "${workspaceFolder}/src/Api",
            "stopAtEntry": false,
            "requireExactSource": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}